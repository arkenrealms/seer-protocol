{
  "name": "@arken/seer-protocol",
  "version": "0.1.10",
  "scripts": {
    "build": "npm-run-all dist",
    "clean": "del-cli ./build && make-dir ./build",
    "dist": "npm-run-all clean tsc:*",
    "test": "jest --runInBand",
    "publish": "npm publish --access=public",
    "tsc:1": "rm -rf ./build && mkdir ./build && cp package.json ./build && NODE_ENV=production NODE_OPTIONS=--max-old-space-size=8192 tsc -p tsconfig.build.json --listFiles"
  },
  "dependencies": {
    "@trpc/client": "11.0.0-rc.660",
    "@trpc/server": "11.0.0-rc.660",
    "make-dir-cli": "^3",
    "mongoose": "^8",
    "pluralize": "^8",
    "jest": "^29",
    "@types/jest": "^29",
    "@types/node": "^20",
    "npm-run-all": "^4.1.5",
    "zod": "^3",
    "dotenv": "^16",
    "lodash": "^4",
    "dayjs": "^1"
  },
  "devDependencies": {
    "del-cli": "^5"
  }
}
